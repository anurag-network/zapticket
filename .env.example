# ZapTicket Environment Configuration
# Copy this file to .env and update values for your environment

# ===================
# Database
# ===================
POSTGRES_USER=zapticket
POSTGRES_PASSWORD=zapticket_secret
POSTGRES_DB=zapticket

# ===================
# Redis
# ===================
REDIS_PASSWORD=

# ===================
# Meilisearch
# ===================
MEILISEARCH_MASTER_KEY=zapticket_master_key

# ===================
# MinIO
# ===================
MINIO_ROOT_USER=zapticket
MINIO_ROOT_PASSWORD=zapticket_secret

# ===================
# JWT
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===================
# Application
# ===================
NODE_ENV=production
API_PORT=3001
WEB_PORT=3000

# ===================
# URLs (for external access)
# ===================
# For Docker: http://localhost:3001
# For Kubernetes: http://api.zapticket.svc.cluster.local:3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ===================
# Docker Registry (for Kubernetes)
# ===================
REGISTRY=your-registry
IMAGE_TAG=latest
